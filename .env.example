# ===========================================
# ALPHA KELASSI — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# Ne commitez JAMAIS .env.local dans git
# ===========================================

# --- FIREBASE (Web SDK — exposé côté client) ---
# Dashboard: https://console.firebase.google.com → Paramètres projet → Config web
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyXxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=votre-projet.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=votre-projet
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=votre-projet.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# --- FIREBASE (Admin SDK — serveur uniquement, ne pas exposer) ---
# Dashboard: Paramètres projet → Comptes de service → Générer une clé privée
FIREBASE_PROJECT_ID=votre-projet
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@votre-projet.iam.gserviceaccount.com
# La clé privée doit être sur une seule ligne avec \n pour les sauts de ligne
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nVOTRE_CLE_ICI\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=gen-lang-client-0394867200.firebasestorage.app

# --- UPSTASH REDIS (rate limiting + cache) ---
# Dashboard: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxx
# Pour BullMQ (connexion directe Redis)
QUEUE_REDIS_URL=rediss://default:password@xxxx.upstash.io:6379

# --- GOOGLE GEMINI AI ---
# Dashboard: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyXxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- STRIPE ---
# Dashboard: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM_MONTHLY=price_xxxxxxxxxx
STRIPE_PRICE_PREMIUM_YEARLY=price_xxxxxxxxxx

# --- CINETPAY (Mobile Money Congo) ---
CINETPAY_API_KEY=xxxxxxxxxxxxxxxxxx
CINETPAY_SITE_ID=xxxxxxxxxx
CINETPAY_SECRET_KEY=xxxxxxxxxxxxxxxxxx
CINETPAY_NOTIFY_URL=https://api.alpha-kelassi.com/webhooks/cinetpay

# --- AFRICA'S TALKING (OTP SMS fallback) ---
AT_API_KEY=atsk_xxxxxxxxxxxxxxxxxx
AT_USERNAME=alpha-kelassi
AT_SENDER_ID=Kelassi

# --- MONITORING ---
SENTRY_DSN=https://xxxxxxxx@oxxxxxxx.ingest.sentry.io/xxxxxxxx
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
METRICS_TOKEN=change-me-in-production

# --- API (Hono) ---
PORT=3001
INTERNAL_API_URL=http://localhost:3001
INTERNAL_API_SECRET=change-me-in-production

# --- APP ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
NODE_ENV=development
